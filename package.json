{
	"name": "obsidian-group-enhancer-for-bases",
	"version": "0.1.0",
	"description": "Provides enhanced features for grouped views in Obsidian Bases.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"plugin",
		"bases",
		"groups",
		"collapse",
		"fold"
	],
	"author": "TfTHacker",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "24.6.1",
		"@typescript-eslint/eslint-plugin": "5.29.0",
		"@typescript-eslint/parser": "5.29.0",
		"builtin-modules": "3.3.0",
		"esbuild-wasm": "^0.25.10",
		"obsidian": "latest",
		"tslib": "2.8.1",
		"typescript": "^5.9.3"
	}
}
